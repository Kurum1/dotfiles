#!/bin/zsh

# 1. 自动 add 改动过的文件
if [ $# -gt 0 ]; then
    echo "➕ 正在添加文件: $@"
    chezmoi add "$@"
fi

# 2. 展示 Diff
echo -e "\n\033[1;33m--- 🔍 变更内容预览 --- \033[0m"
chezmoi diff

# 3. 交互式确认
echo -e "\n\033[1;32m是否确认提交并推送到 GitHub? (y/n)\033[0m"
read -k 1 -r
echo

if [[ $REPLY =~ ^[Yy]$ ]]; then
    local SOURCE_PATH=$(chezmoi source-path)
    pushd "$SOURCE_PATH" > /dev/null
    
    git add .
    git commit -m "Update dotfiles: $(date +'%Y-%m-%d %H:%M:%S')"
    
    echo "🚀 正在通过 GitHub CLI 推送..."
    git push
    
    popd > /dev/null
    echo -e "\n✅ 同步成功！"
else
    echo -e "\n❌ 操作已取消。"
fi
